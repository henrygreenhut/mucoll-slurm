{
  "remote_host": "perlmutter",
  "remote_dir": "~/mucoll/mucoll-slurm",
  "result_dir": "pfn_results",
  "poll_seconds": 120,
  "max_submitted": 2,
  "bundle_size": 4,
  "bundle_script": "submit_libtest_bundle.slurm",
  "bundle_config": "libtest_paired_eval_supervisor.json",
  "runs": [
    {
      "label": "EVAL_n42_paired_overlap",
      "job_name": "lte_n42_pair",
      "script": "submit_libtest_evaluate.slurm",
      "max_windows": 20,
      "train_args": "--source-label A0_n42_paper --point-units 500 --bootstrap-reps 200 --bootstrap-units 100 --batch-size 8"
    },
    {
      "label": "EVAL_n126_paired_overlap",
      "job_name": "lte_n126_pair",
      "script": "submit_libtest_evaluate.slurm",
      "max_windows": 20,
      "train_args": "--source-label A0_n126_scaled --point-units 500 --bootstrap-reps 200 --bootstrap-units 100 --batch-size 2"
    }
  ]
}
